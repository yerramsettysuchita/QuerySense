# ─────────────────────────────────────────────────────────────────────────────
# QuerySense — environment variables
# Copy to .env and fill in real values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────

# Environment: development | test | staging | production
ENVIRONMENT=development

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production — startup will fail if left as default
SECRET_KEY=your-secret-key-change-in-production

DEBUG=true

# Public URL of the frontend (used in Slack alert links)
APP_BASE_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins
# In production: https://yourapp.onrender.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Databases ─────────────────────────────────────────────────────────────────

# Main PostgreSQL — monitored by QuerySense for slow queries
MAIN_DB_URL=postgresql://postgres:postgres@localhost:5432/querysense_main

# Shadow PostgreSQL — used for safe query benchmarking (read-only replica or clone)
SHADOW_DB_URL=postgresql://postgres:postgres@localhost:5433/querysense_shadow

# App PostgreSQL — stores QuerySense's own data (users, workspaces, API keys, etc.)
APP_DB_URL=postgresql://postgres:postgres@localhost:5434/querysense_app

# MySQL (optional) — leave blank to disable MySQL monitoring
MYSQL_URL=

# Redis — used by Celery for task queue and result storage
REDIS_URL=redis://localhost:6379

# ── Connection Pool (tune for your server capacity) ───────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ── AI ────────────────────────────────────────────────────────────────────────

# OpenRouter API key — powers the AI agent (Claude, GPT-4o-mini fallback)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI API key — used for GPT-4o Vision (schema diagram analysis)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Observability ────────────────────────────────────────────────────────────

# Sentry DSN — sign up free at sentry.io. Leave blank to disable error tracking.
SENTRY_DSN=

# Prometheus UI URL — shown as a link in the System Health panel.
# Set to your Prometheus instance URL. Leave blank to hide the link.
NEXT_PUBLIC_PROMETHEUS_URL=

# ── Slack ─────────────────────────────────────────────────────────────────────

# Incoming Webhook URL for alert notifications
SLACK_WEBHOOK_URL=

# Set to true to enable Slack alerts for slow queries and anomalies
SLACK_ALERTS_ENABLED=false

# Required for verifying Slack request signatures (from app settings → Basic Information)
SLACK_SIGNING_SECRET=

# Bot token for Slack bot commands (starts with xoxb-)
SLACK_BOT_TOKEN=

# ── Monitoring ────────────────────────────────────────────────────────────────

# Queries slower than this threshold (ms) are flagged as slow
SLOW_QUERY_THRESHOLD_MS=500

# How often the monitor polls pg_stat_statements (seconds)
POLL_INTERVAL_SECONDS=30

# Anomaly detection: flag queries that deviate N standard deviations from their baseline
ANOMALY_STDDEV_MULTIPLIER=2.0

# How many recent execution times to use as the rolling baseline
QUERY_HISTORY_WINDOW=50

# ── Shadow Benchmarking ───────────────────────────────────────────────────────

# Max rows to copy from main DB to shadow DB for benchmarking
SHADOW_SAMPLE_ROWS=10000

# Number of iterations for each benchmark run
BENCHMARK_ITERATIONS=100
